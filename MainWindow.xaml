<Window x:Class="HQGuard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HQ过检测守护程序" Height="500" Width="700"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <TextBlock Grid.Row="0" Text="HQ过检测守护程序 v1.0" FontSize="18" FontWeight="Bold"
                   Margin="0,0,0,8"/>

        <!-- 状态栏 -->
        <Border Grid.Row="1" Background="#F5F5F5" BorderBrush="#DDD" BorderThickness="1"
                CornerRadius="6" Padding="12,8" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 引擎状态 -->
                <TextBlock Grid.Column="0" Text="拦截引擎:" VerticalAlignment="Center"/>
                <TextBlock x:Name="EngineStatus" Grid.Column="1" Text="检测中..." 
                           Foreground="Gray" Margin="4,0,16,0" VerticalAlignment="Center"/>

                <!-- 拦截状态 -->
                <TextBlock Grid.Column="2" Text="拦截:" VerticalAlignment="Center"/>
                <TextBlock x:Name="BlockStatus" Grid.Column="3" Text="未启动"
                           Foreground="Gray" Margin="4,0,0,0" VerticalAlignment="Center"/>

                <!-- 状态灯 -->
                <Ellipse x:Name="StatusDot" Grid.Column="4" 
                         Width="12" Height="12" Fill="Gray" 
                         HorizontalAlignment="Right" VerticalAlignment="Center"
                         Margin="0,0,4,0"/>
            </Grid>
        </Border>

        <!-- 日志框 -->
        <TextBox x:Name="LogBox" Grid.Row="2" 
                 FontFamily="Consolas" FontSize="12"
                 IsReadOnly="True" VerticalScrollBarVisibility="Visible"
                 TextWrapping="Wrap" Margin="0,0,0,8"/>

        <!-- 操作按钮区 -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="ToggleBtn" Grid.Column="0" 
                    Content="开启过检测" Width="140"
                    Click="ToggleBtn_Click"/>

            <Button Grid.Column="1" Content="清空日志" 
                    Margin="8,0,0,0"
                    Click="ClearLog_Click"/>

            <!-- 域名列表 -->
            <StackPanel Grid.Column="2" Margin="16,0,0,0" VerticalAlignment="Center">
                <TextBlock FontSize="11" Foreground="Gray">
                    监控域名：cschannel.anticheatexpert.com, cschannel2.anticheatexpert.com
                </TextBlock>
                <TextBlock FontSize="11" Foreground="Gray">
                    拦截端口：80, 443
                </TextBlock>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
